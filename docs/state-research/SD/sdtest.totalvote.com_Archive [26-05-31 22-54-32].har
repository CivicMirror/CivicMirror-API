           <span class=\"failureNotification\">\r\n                    \r\n                </span>\r\n                <div data-val-validationGroup=\"LoginUserValidationGroup\" id=\"MainContent_LoginUser_LoginUserValidationSummary\" class=\"failureNotification\" data-valsummary=\"true\" style=\"display:none;\">\r\n\r\n\t</div>\r\n                <div class=\"accountInfo\">\r\n                    <fieldset class=\"login\">\r\n                        <legend>Account Information</legend>\r\n                        <p>\r\n                            <label for=\"MainContent_LoginUser_UserName\" id=\"MainContent_LoginUser_UserNameLabel\">Username:</label>\r\n                            <input name=\"ctl00$MainContent$LoginUser$UserName\" type=\"text\" id=\"MainContent_LoginUser_UserName\" class=\"textEntry\" />\r\n                            <span data-val-controltovalidate=\"MainContent_LoginUser_UserName\" data-val-errormessage=\"User Name is required.\" data-val-validationGroup=\"LoginUserValidationGroup\" id=\"MainContent_LoginUser_UserNameRequired\" title=\"User Name is required.\" class=\"failureNotification\" data-val=\"true\" data-val-evaluationfunction=\"RequiredFieldValidatorEvaluateIsValid\" data-val-initialvalue=\"\" style=\"visibility:hidden;\">*</span>\r\n                        </p>\r\n                        <p>\r\n                            <label for=\"MainContent_LoginUser_Password\" id=\"MainContent_LoginUser_PasswordLabel\">Password:</label>\r\n                            <input name=\"ctl00$MainContent$LoginUser$Password\" type=\"password\" id=\"MainContent_LoginUser_Password\" class=\"passwordEntry\" />\r\n                            <span data-val-controltovalidate=\"MainContent_LoginUser_Password\" data-val-errormessage=\"Password is required.\" data-val-validationGroup=\"LoginUserValidationGroup\" id=\"MainContent_LoginUser_PasswordRequired\" title=\"Password is required.\" class=\"failureNotification\" data-val=\"true\" data-val-evaluationfunction=\"RequiredFieldValidatorEvaluateIsValid\" data-val-initialvalue=\"\" style=\"visibility:hidden;\">*</span>\r\n                        </p>\r\n                        <p>\r\n                            <label for=\"MainContent_LoginUser_txtYubi\" id=\"MainContent_LoginUser_YubiLabel\">Touch Key:</label>\r\n                            <input name=\"ctl00$MainContent$LoginUser$txtYubi\" type=\"password\" id=\"MainContent_LoginUser_txtYubi\" class=\"textEntry\" />\r\n\r\n                            <span data-val-controltovalidate=\"MainContent_LoginUser_txtYubi\" data-val-errormessage=\"Yubi Key Required\" data-val-validationGroup=\"LoginUserValidationGroup\" id=\"MainContent_LoginUser_YubiKeyRequired\" title=\"Password is required.\" class=\"failureNotification\" data-val=\"true\" data-val-evaluationfunction=\"RequiredFieldValidatorEvaluateIsValid\" data-val-initialvalue=\"\" style=\"visibility:hidden;\">*</span>\r\n                        </p>\r\n                        <p>\r\n                            \r\n                        </p>\r\n                    </fieldset>\r\n                    <p class=\"submitButton\">\r\n                        <input type=\"submit\" name=\"ctl00$MainContent$LoginUser$LoginButton\" value=\"Log In\" onclick=\"javascript:WebForm_DoPostBackWithOptions(new WebForm_PostBackOptions(&quot;ctl00$MainContent$LoginUser$LoginButton&quot;, &quot;&quot;, true, &quot;LoginUserValidationGroup&quot;, &quot;&quot;, false, false))\" id=\"MainContent_LoginUser_LoginButton\" />\r\n                        &nbsp;<span id=\"MainContent_LoginUser_lblNote\" style=\"color:#993333;font-weight: 700\"></span>\r\n                    </p>\r\n                </div>\r\n            \r\n    \r\n</div>\r\n\r\n\r\n\t\t\t\t</div>\r\n\t\t\t\t<div class=\"clear\" />\r\n\t\t\t</div>\r\n\t\t\r\n\r\n<script type=\"text/javascript\">\r\n//<![CDATA[\r\nwindow.__TsmHiddenField = $get('rsmMaster_TSM');WebForm_AutoFocus('MainContent_LoginUser_UserName');Sys.Application.add_