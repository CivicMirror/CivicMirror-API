            "text": "/* DEFAULTS\r\n----------------------------------------------------------*/\r\n\r\nbody, form  {\r\n\tfont: 10pt Arial, Helvetica, sans-serif;\r\n\tbackground: #f7f7f7 no-repeat 50% top;\r\n\t/*background-image: url('../images/backgrnd.jpg');*/\r\n\tmargin: 0 auto;\r\n\tpadding: 0 0 0 0;\r\n\tcolor: black;\r\n\ttext-align: left;\r\n}\r\n\r\n.mainlinkbar { \r\n\twidth: 850px;\r\n    background-image: url('../images/linkbar-bk.jpg');\r\n\tbackground-color: white;\r\n\tmargin: 0 auto;\r\n\tpadding: 0 0 0 0;\r\n\ttext-align: left;\r\n}\r\n\r\n.masterheader {\r\n\tposition: relative;\r\n\tmargin: 0 Auto;\r\n\tpadding: 0px;\r\n\tpadding-top: 4px;\r\n\tbackground-image: url('../images/SouthDakotaBanner.png');\r\n\tbackground-repeat: no-repeat;\r\n\tbackground-position: 50% top;\r\n\twidth: 990px;\r\n\theight: 103px;\r\n\ttext-align: left;\r\n}\r\n\r\n.masterheadertest {\r\n\tposition: relative;\r\n\tmargin: 0 Auto;\r\n\tpadding: 0px;\r\n\tpadding-top: 4px;\r\n\tbackground-image: url('../images/SouthDakotaBanner-test.png');\r\n\tbackground-repeat: no-repeat;\r\n\tbackground-position: 50% top;\r\n\twidth: 990px;\r\n\theight: 103px;\r\n\ttext-align: left;\r\n}\r\n\r\n.masterheaderdev {\r\n\tposition: relative;\r\n\tmargin: 0 Auto;\r\n\tpadding: 0px;\r\n\tpadding-top: 4px;\r\n\tbackground-image: url('../images/SouthDakotaBanner-dev.png');\r\n\tbackground-repeat: no-repeat;\r\n\tbackground-position: 50% top;\r\n\twidth: 990px;\r\n\theight: 103px;\r\n\ttext-align: left;\r\n}\r\n\r\n.mastersearch\r\n{\r\n\tposition: relative;\r\n\tmargin: 0px auto;\r\n\tpadding: 0px;\r\n\tbackground-color: #2E3547;\t\r\n\twidth: 988px;\r\n\theight: 50px;\r\n\ttext-align: center;\r\n\tcolor: White;\r\n\tborder-style: solid;\r\n\tborder-width: 1px;\r\n\tborder-color: Black;\r\n}\r\n\r\n.textboxcaption\r\n{\r\n    font-size: smaller;\r\n    vertical-align:super;\r\n    text-align:center;\r\n    color: White;\r\n\r\n}\r\n\r\n.electionHeader{\r\n\tbackground-color: Blue !important;\r\n\tpadding: 3px 6px 3px 6px;\r\n\ttext-decoration: none;\r\n\tfont-size: 1.2em;\r\n\tfont-weight: bold;\r\n\tborder-radius: 6px;\r\n\tbackground: -webkit-linear-gradient(rgb(11,84,137), rgb(11,84,137)); /* For Safari 5.1 to 6.0 */\r\n\tbackground: -o-linear-gradient(rgb(11,84,137), rgb(11,84,137)); /* For Opera 11.1 to 12.0 */\r\n\tbackground: -moz-linear-gradient(rgb(11,84,137), rgb(11,84,137)); /* For Firefox 3.6 to 15 */\r\n\tbackground: linear-gradient(rgb(11,84,137), rgb(11,84,137)); /* Standard syntax (must be last) */\r\n}"
