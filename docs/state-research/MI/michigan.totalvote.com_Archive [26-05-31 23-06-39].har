            "text": "\r\n\r\n<!DOCTYPE html>\r\n<html>\r\n<head><title>\r\n\tDetroit Election Results\r\n</title><meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge,chrome=1\" /><meta content=\"text/html; charset=windows-1252\" http-equiv=\"Content-Type\" /><meta name=\"viewport\" content=\"width=device-width, minimum-scale=1.0, maximum-scale=1.0\" />\r\n\r\n    <link href=\"/Styles/styles.css?v=0.0.0.0\" rel=\"stylesheet\" />\r\n    <link href=\"/Styles/stylesmobile.css\" rel=\"stylesheet\" /><link href=\"/Styles/sidemenu.css\" rel=\"stylesheet\" /><link href=\"/Styles/font_PT_Sans.css\" rel=\"stylesheet\" /><link href=\"/Styles/font_Montserrat.css\" rel=\"stylesheet\" /><link href=\"https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700&amp;display=swap\" rel=\"stylesheet\" />\r\n\r\n    <script src=\"/Scripts/jquery/jquery-1.11.0.min.js\"></script>\r\n    \r\n    <script src=\"/Scripts/Chart.min.js\"></script>\r\n    <script src=\"/Scripts/utils.js\"></script>\r\n    <script>\r\n        var ServiceRoot = 'https://phillyresws.azurewebsites.us/';\r\n        var Maps = {};\r\n        var Bound = {};\r\n        var mapBuilt = [];\r\n        var CandColors = {};\r\n        const constReported = 'Reported';\r\n        const constNotReported = 'Not Reported';\r\n\r\n        window.onload = function () {\r\n            //var cid = getUrlVars()[\"cid\"];\r\n            var WatchList = getCookie(\"OHTracked\");\r\n            if (WatchList == undefined)\r\n                WatchList = \"\";\r\n            //if (cid == \"73\") {\r\n            //    var CableScrollerLink = document.getElementById(\"cablescrollerli\");\r\n            //    if (CableScrollerLink !== undefined && CableScrollerLink !== null) {\r\n            //        CableScrollerLink.style.display = \"inline-block\";\r\n            //    }\r\n            //}\r\n\r\n            var checked = WatchList.split(\"_\");\r\n            for (var i = 0; i < checked.length; i++) {\r\n                var checkbox = document.getElementById(\"chk-\" + checked[i]);\r\n                if (checkbox !== null)\r\n                    checkbox.checked = true;\r\n            };\r\n        };\r\n\r\n        $(document).click(function (event) {\r\n            if (!$(event.target).closest('.search-icon-wrapper').length) {\r\n                if (document.getElementById('header-search-box')) {\r\n                    if (document.getElementById('header-search-box').style.visibility == 'visible') {\r\n                        document.getElementById('header-search-box').style.visibility = 'hidden';\r\n                    }\r\n                    $('.search-icon-wrapper').removeClass('search-icon-wrapper-hover');\r\n                    $('.search-icon').removeClass('search-icon-hover');\r\n                }\r\n            }\r\n        });\r\n\r\n        $(document).click(function (event) {\r\n            if (!$(event.target).closest('.mtc-icon-position').length) {\r\n                if (document.getElementById('header-share-box')) {\r\n                    if (document.getElementById('header-share-box').style.visibility == 'visible') {\r\n                        document.getElementById('header-share-box').style.visibility = 'hidden';\r\n                    }\r\n                    $('.mtc-icon-position').removeClass('mtc-icon-position-hover');\r\n                    $('.share-icon').removeClass('share-icon-hover');\r\n                }\r\n            }\r\n        });\r\n\r\n        $(document).click(function (event) {\r\n            if (!$(event.target).closest('#mainmenu').length && !$(event.target).closest('#menuToggle').length) {\r\n                //if ($('#mainmenu').css(\"visibility\") == 'visible') {\r\n                //    //$('#mainmenu').css('visibility', 'hidden');\r\n                //}\r\n                if ($('#mainmenu').hasClass(\"open\")) {\r\n                    $('#menuToggle').click();\r\n                }\r\n            }\r\n        });\r\n    </script>\r\n    <script>\r\n        (function (i, s, o, g, r, a, m) {\r\n            i['GoogleAnalyticsObject'] = r; i[r] = i[r] || function () {\r\n                (i[r].q = i[r].q || []).push(arguments)\r\n            }, i[r].l = 1 * new Date(); a = s.createElement(o),\r\n                m = s.getElementsByTagName(o)[0]; a.async = 1; a.src = g; m.parentNode.insertBefore(a, m)\r\n        })(window, document, 'script', 'https://www.google-analytics.com/analytics.js', 'ga');\r\n\r\n        ga('create', 'UA-98212275-1', 'auto');\r\n        ga('send', 'pageview');\r\n\r\n    </script>\r\n    <!-- Global site tag (gtag.js) - Google Analytics -->\r\n    <script async src=\"https://www.googletagmanager.com/gtag/js?id=UA-161980962-1\"></script>\r\n    <script>\r\n        window.dataLayer = window.dataLayer || [];\r\n        function gtag() { dataLayer.push(arguments); }\r\n        gtag('js', new Date());\r\n\r\n        gtag('config', 'UA-161980962-1');\r\n    </script>\r\n\r\n    <script type=\"text/javascript\">\r\n        var clicked = false;\r\n        $('body').on({\r\n            'touchmove': function (e) {\r\n                stick();\r\n            }\r\n        });\r\n        $(document).ready(function () {\r\n            jQuery.fn.reverse = [].reverse;\r\n\r\n            var i = 1;\r\n            var topMenu = $('.header-menu-links');\r\n            if (topMenu !== undefined && topMenu.children !== undefined) {\r\n                var tabindex = 1;\r\n                $.each(topMenu.find('a,.share-icon,.search-icon,input'), function (index) {\r\n\r\n                    $(this).attr(\"tabindex\", tabindex);\r\n                    tabindex++;\r\n                });\r\n                var sos = $('#lnkSOSName');\r\n\r\n                if (sos !== undefined) {\r\n\r\n                    sos.attr(\"tabindex\", tabindex);\r\n                    tabindex++;\r\n                }\r\n                var header = $('.header-box-wrapper');\r\n                if (header !== undefined) {\r\n                    $.each(header.find('input,a'), function (index) {\r\n                        tabindex++;\r\n                        $(this).attr(\"tabindex\", tabindex);\r\n                    });\r\n                }\r\n                var allOthers = $('.outside-wrapper');\r\n                if (allOthers != undefined) {\r\n                    $.each(allOthers.find('input,a'), function (index) {\r\n                        if (!$(this).is(\"[tabindex]\")) {\r\n                            tabindex++;\r\n                            $(this).attr('tabindex', tabindex);\r\n                        }\r\n                    });\r\n                }\r\n            }\r\n\r\n            $('#btnElectResources').click(function () {\r\n                if (!clicked) {\r\n                    clicked = true;\r\n                    $(\"html, body\").delay(300).animate({ scrollTop: $(document).height() }, \"slow\");\r\n                    return;\r\n                }\r\n                clicked = false;\r\n            });\r\n        })\r\n\r\n    </script>\r\n    <script type=\"text/javascript\" src=\"/Scripts/sticky.js\"></script>\r\n    <link id=\"countyStyles\" rel=\"stylesheet\" type=\"text/css\" href=\"/Styles/County/06.css\" />\r\n</head>\r\n<body>\r\n    <form method=\"post\" action=\"./ResultsExport.aspx?cid=06\" id=\"ctl01\">\r\n<div class=\"aspNetHidden\">\r\n<input type=\"hidden\" name=\"__EVENTTARGET\" id=\"__EVENTTARGET\" value=\"\" />\r\n<input type=\"hidden\" name=\"__EVENTARGUMENT\" id=\"__EVENTARGUMENT\" value=\"\" />\r\n<input type=\"hidden\" name=\"__VIEWSTATE\" id=\"__VIEWSTATE\" value=\"\" />\r\n</div>\r\n\r\n<script type=\"text/javascript\">\r\n//<![CDATA[\r\nvar theForm = document.forms['ctl01'];\r\nif (!theForm) {\r\n    theForm = document.ctl01;\r\n}\r\nfunction __doPostBack(eventTarget, eventArgument) {\r\n    if (!theForm.onsubmit || (theForm.onsubmit() != false)) {\r\n        theForm.__EVENTTARGET.value = eventTarget;\r\n        theForm.__EVENTARGUMENT.value = eventArgument;\r\n        theForm.submit();\r\n    }\r\n}\r\n//]]>\r\n</script>\r\n\r\n\r\n<div class=\"aspNetHidden\">\r\n\r\n\t<input type=\"hidden\" name=\"__VIEWSTATEGENERATOR\" id=\"__VIEWSTATEGENERATOR\" value=\"73C1085B\" />\r\n\t<input type=\"hidden\" name=\"__EVENTVALIDATION\" id=\"__EVENTVALIDATION\" value=\"\" />\r\n</div>\r\n        <input type=\"hidden\" name=\"ctl00$hidElectionType\" id=\"hidElectionType\" value=\"primary\" />\r\n        <input type=\"hidden\" name=\"ctl00$hidElectionDate\" id=\"hidElectionDate\" value=\"8/5/2025\" />\r\n        <input type=\"hidden\" name=\"ctl00$hidPrecinctsReported\" id=\"hidPrecinctsReported\" value=\"430\" />\r\n        <input type=\"hidden\" name=\"ctl00$hidPrecinctsPartial\" id=\"hidPrecinctsPartial\" value=\"0\" />\r\n        <input type=\"hidden\" name=\"ctl00$hidPrecinctsNotReported\" id=\"hidPrecinctsNotReported\" value=\"0\" />\r\n        <input type=\"hidden\" name=\"ctl00$hidVoterTurnout\" id=\"hidVoterTurnout\" value=\"86500\" />\r\n        <input type=\"hidden\" name=\"ctl00$hidVoterTotal\" id=\"hidVoterTotal\" value=\"431814\" />\r\n        <div id=\"fader\">\r\n            <h1>Preparing Export...</h1>\r\n        </div>\r\n        <div class=\"outside-wrapper\">\r\n            <div id=\"google_translate_element\"></div>\r\n            <div>\r\n                \r\n            </div>\r\n            <div id=\"sticky-anchor\"></div>\r\n            <div id=\"sticky\" class=\"top-colorbar\">\r\n                <div class=\"menubar-wrapper\">\r\n                    <a href=\"\" id=\"menuToggle\" tabindex=\"1\" title=\"menu\"><span class=\"navClosed\"><em>menu</em></span></a>\r\n                    <div id=\"pnlLastUpdate\" class=\"last-updated\">\r\n\t\r\n                        Results Last Updated: 8/6/2025 4:39:13 AM EST\r\n                    \r\n</div>\r\n                    <div id=\"pnlHeaderLine\" class=\"header-menu-links\">\r\n\t\r\n                        <div>\r\n                            \r\n                        </div>\r\n                        \r\n    <h2>\r\n        <a id=\"hdrNavLinks_hdrlnkHome\" href=\"/Detroit\">Home</a></h2>\r\n\r\n                        \r\n                        \r\n                        <h2>\r\n                            <a id=\"lnkhdrTrackedContests\" href=\"MyTrackedContests.aspx?cid=06\">My Tracked Contests</a>\r\n                        </h2>\r\n                        \r\n                        <div class=\"mtc-icon-position\">\r\n                            <div class=\"share-icon \" title=\"Share\" onclick=\"ShareClick()\"></div>\r\n                            <div id=\"header-share-box\" class=\"share-container\">\r\n                                <div class=\"share-header\">SHARE ON</div>\r\n                                <div class=\"share-icon-wrapper\">\r\n                                    <div class=\"facebook\"><a href=\"https://www.facebook.com/sharer/sharer.php?u=https://michigan.totalvote.com/Detroit\" target=\"_blank\"><img alt=\"Share on Facebook\" title=\"Facebook\" src=\"/Images/facebook.png\" class=\"face-nine\" /></a></div><div class=\"twitter\"><a href=\"https://twitter.com/intent/tweet?text=I'm checking out Detroit's election results at: https://michigan.totalvote.com/Detroit&hashtags=Detroit,electionresults\" target=\"_blank\" ><img alt=\"Share on Twitter\" title=\"Twitter\" src=\"/Images/twitter.png\" class=\"twit-nine\" /></a></div><div class=\"linkedin\"><a href=\"https://www.linkedin.com/shareArticle?mini=true&url=https://michigan.totalvote.com/Detroit&title=Detroit%20election%20results&Detroit%20election%20results&source=Detroit%20Election%20Night%20Reporting\" target=\"_blank\"><img alt=\"Share on LinkedIn\" title=\"LinkedIn\" src=\"/Images/linkedin.png\" class=\"link-nine\" /></a></div>\r\n                                    \r\n                                </div>\r\n                            </div>\r\n                        </div>\r\n                        <div class=\"search-icon-wrapper\">\r\n                            <div class=\"search-icon\" title=\"Search\" onclick=\"MagClick()\"></div>\r\n                            <div id=\"header-search-box\" class=\"search-container\">\r\n                                <div class=\"search-box-wrapper\">\r\n                                    <!--Search box here -->\r\n                                    <input name=\"ctl00$txtQuickSearch\" type=\"text\" id=\"txtQuickSearch\" class=\"textboxSmallTransparent\" title=\"Search for Contest or Candidate\" placeholder=\"Search...\" />\r\n                                    \r\n                                    <input type=\"submit\" name=\"ctl00$btnSearch\" value=\"Search\" id=\"btnSearch\" class=\"search-button\" />\r\n                                </div>\r\n                            </div>\r\n                        </div>\r\n                    \r\n</div>\r\n                </div>\r\n                \r\n                \r\n                <div></div>\r\n            </div>\r\n            <!--End Top Blue Bar-->\r\n            <div class=\"top-header\">\r\n                <div id=\"pnlHeader\" class=\"section group\">\r\n\t\r\n                    <div class=\"desktop county-seal\">\r\n                        <a id=\"lnkSOSName\" class=\"header-seal\" href=\"/Detroit\"><h2 style=\"text-align: center;\"><span>City of Detroit</span><br/>Unofficial Election Results</h2></a>\r\n                    </div>\r\n                    <div class=\"mobile mobile-seal\">\r\n                        <a id=\"lnkStateSOS\" class=\"header-seal\" href=\"/Detroit\"><h2 style=\"text-align: center;\"><span>City of Detroit</span><br/>Unofficial Election Results</h2></a>\r\n                    </div>\r\n                    \r\n                    <!--End top-header-box1-->\r\n                    \r\n                    <!--End top-header-box2-->\r\n                \r\n</div>\r\n                <!--End Section Group-->\r\n            </div>\r\n            <!--End Top Header-->\r\n            <div class=\"header-box-wrapper\">\r\n                <div class=\"section group\">\r\n                    <div class=\"col header-box1\">\r\n                        <a id=\"lnkElectionInfo\" class=\"aspNetDisabled header-box-home\"><h1 class=\"official\">State</h1><h2>Primary Election<span>August 5, 2025</span></h2></a>\r\n                    </div>\r\n                    <!--End Header Box 1-->\r\n                    <div class=\"col header-box2\">\r\n                        <a id=\"lnkVoterTurnout\" class=\"button\" href=\"VoterTurnoutDetails.aspx?cid=06\">\r\n                            <div class=\"header-box-content-top\">\r\n                                <h1>Voter Turnout<div><span style=\"font-size: 13px; font-weight: bold;\">Registered Voters: 518,314</span></div>\r\n    <br/><span class=\"turount-last-updated-text\">Results Last Updated</span><br/><span class=\"turnout-last-updated-time\">8/6/2025 4:39:13 AM EST</span>\r\n</h1>\r\n                            </div>\r\n                            <!--End header-box2-content-top-->\r\n                            <div id=\"turnoutgraph\" class=\"header-box-content-bottom\">\r\n                                \r\n                                <div class=\"animate-position desktop\">\r\n                                    <div style=\"height: 150px\"><canvas id=\"voter-turnout\" width=\"100\" height=\"150\"></canvas><div class=\"dough-percent\"><span class=\"int\">16</span><span class=\"dec\">.69%</span></div></div>\r\n                                </div>\r\n                                <!--End Animate Position-->\r\n                                <div class=\"animate-position mobile\">\r\n                                    <div><canvas id=\"voter-turnout-mobile\"></canvas><div class=\"dough-percent\"><span class=\"int\">16</span><span class=\"dec\">.69%</span></div></div>\r\n                                </div>\r\n                                <!--End Animate Position-->\r\n                            </div>\r\n                            <!--End header-box-content-bottom-->\r\n                            </a>\r\n                    </div>\r\n                    <!--End Header Box 2-->\r\n                    <div id=\"pnlHeaderPrecinctsReporting\" class=\"col header-box2\">\r\n\t\r\n                        <a id=\"lnkPrecinctsReporting\" class=\"button\" href=\"VoterTurnoutDetails.aspx?cid=06&amp;cat=PREC\">\r\n                            <div class=\"header-box-content-top\">\r\n                                <h1>Precincts Reporting<div style='color: white; font-size: 18px; font-weight: bold;'><span style='font-size: 16px; font-weight: bold;'>430/430 </span></div></h1>\r\n                            </div>\r\n                            <!--End header-box2-content-top-->\r\n                            <div id=\"divVoteCenterPercent\" class=\"header-box-content-bottom\">\r\n                                \r\n                                <div class=\"animate-position desktop\">\r\n                                    <div style=\"height: 150px\"><canvas id=\"precinct-reported\" width=\"100\" height=\"150\"></canvas><div class=\"dough-percent\"><span class=\"int\">100</span><span class=\"dec\">.0%</span></div></div>\r\n                                </div>\r\n                                <!--End Animate Position-->\r\n                                <div class=\"animate-position mobile\">\r\n                                    <div><canvas id=\"precinct-reported-mobile\"></canvas><div class=\"dough-percent\"><span class=\"int\">100</span><span class=\"dec\">.0%</span></div></div>\r\n                                </div>\r\n                                <!--End Animate Position-->\r\n                            </div>\r\n                            <!--End header-box-content-bottom-->\r\n                            </a>\r\n                    \r\n</div>\r\n                    <div id=\"chartjs-tooltip\"></div>\r\n                    <!--End Header Box 3-->\r\n                </div>\r\n                <!--End Section Group-->\r\n                \r\n            </div>\r\n            <!--End Header Box Wrapper-->\r\n            \r\n            \r\n            <!--Main Content-->\r\n            <link rel=\"stylesheet\" href=\"/Styles/jquery-ui.css\" />\r\n            \r\n            <script src=\"/Scripts/jquery/jquery-ui.js\"></script>\r\n            \r\n    <div id=\"pnlResultsHeader\" class=\"wrapper-results-header\">\r\n\t\r\n        <div class=\"legislative-header-wrapper\">\r\n            <span id=\"MainContent_lblResultsHeader\">City of Detroit Exports</span>\r\n        </div>\r\n    \r\n</div>\r\n    <div class=\"wrapper-inside\" style=\"padding: 1px 0 11px;\">\r\n        \r\n        <div id=\"MainContent_pnlDetroitExportHeader\" class=\"display-results-box-wrapper\">\r\n\t\r\n            <h1 style=\"text-align: center; padding-bottom: 8px;\">City of Detroit Exports</h1>\r\n        \r\n</div>\r\n        \r\n        <div class=\"county-export-list\">\r\n            \r\n                    <div class=\"county-export-listitem\">\r\n                        <a onclick=\"DownloadFile();\" id=\"MainContent_rptCountyExport_LinkButton1_0\" href=\"javascript:__doPostBack(&#39;ctl00$MainContent$rptCountyExport$ctl00$LinkButton1&#39;,&#39;&#39;)\">Detroit</a>\r\n                    </div>\r\n                \r\n            \r\n        </div>\r\n    </div>\r\n\r\n            \r\n            <div class=\"resources-bar\">\r\n                <div id=\"pnlResources\">\r\n\t\r\n                    \r\n                    <button type=\"button\" id=\"btnElectResources\" class=\"button\" onclick=\"Show_Div(Div_1);\">\r\n                        Election Resources<div class=\"button\"></div>\r\n                    </button>\r\n                    <div id=\"Div_1\" style=\"display: none;\" class=\"slidingDiv\">\r\n                        <div id=\"pnlResource1\" class=\"resource-wrapper\">\r\n\t\t\r\n                            <div id=\"divERVoterTurnout\" class=\"resource-button\">\r\n                                <a id=\"lnkERVoterTurnout\" href=\"VoterTurnoutDetails.aspx?cid=06\">Voter Turnout</a>\r\n                            </div>\r\n                            <div id=\"exportButton\" class=\"resource-button\"> \r\n                                \r\n                                <a id=\"lnkDetroitExport\" href=\"ResultsExport.aspx?cid=06\">City Exports</a>\r\n                            </div>\r\n                            \r\n                            \r\n                              \r\n                             \r\n                            \r\n                            \r\n                            \r\n                            \r\n                            \r\n                            \r\n                        \r\n\t</div>\r\n                        \r\n                        <div class=\"resource-wrapper\">\r\n                            \r\n                        </div>\r\n                        \r\n                    </div>\r\n                \r\n</div>\r\n                <div class=\"bottom-colorbar\"></div>\r\n            </div>\r\n        </div>\r\n        \r\n        <!--End Outside Wrapper-->\r\n        <nav id=\"mainmenu\">\r\n            <a href=\"/Detroit\" title=\"Home\" style=\"display: inline-block;\">Home</a><a href=\"/Detroit/MyTrackedContests.aspx?cid=06\" title=\"My Tracked Contests\" style=\"display: inline-block;\">My Tracked Contests</a><h1>Election Results</h1><a href=\"/Detroit/ResultsSW.aspx?type=MYR&cid=06&map=\" title=\"Mayor\">Mayor</a><a href=\"/Detroit/ResultsSW.aspx?type=CAL&cid=06&map=\" title=\"City Council At Large\">City Council At Large</a><a href=\"/Detroit/ResultsSW.aspx?type=CD2&cid=06&map=\" title=\"Council District 2\">Council District 2</a><a href=\"/Detroit/ResultsSW.aspx?type=CD5&cid=06&map=\" title=\"Council District 5\">Council District 5</a><a href=\"/Detroit/ResultsSW.aspx?type=CD7&cid=06&map=\" title=\"Council District 7\">Council District 7</a><h1>Election Resources</h1><a href=\"/Detroit/VoterTurnoutDetails.aspx?cid=06\" title=\"Voter Turnout\">Voter Turnout</a>\r\n        </nav>\r\n    </form>\r\n    <script type=\"text/javascript\">\r\n        var gPrecLabel1 = 'Vote Centers Reported';\r\n        var gPrecLabel2 = 'Vote Centers Not Reported';\r\n        var gPrecVCText = 'Vote Centers Reporting';\r\n        var gBallotsCast = 'Ballots Cast';\r\n        var gBallotsNotCast = 'Ballots Not Cast';\r\n    </script>\r\n    <script>\r\n        (function ($) {\r\n            $(document).ready(function () {\r\n                $(\".dropbtn\").click(function () {\r\n                    $(this).next('.dropdown-content').toggle();\r\n                });\r\n                //$(\".dropdown\").hover(function(){\r\n                //    $(this).find('.dropdown-content').css('display','block')\r\n                // }, function() {\r\n                //     $(this).find('.dropdown-content').css('display','none');\r\n                // });\r\n\r\n                $('#menuToggle').click(function (e) {\r\n                    //var $parent = $(this).parent('nav');\r\n                    var $parent = $('#mainmenu');\r\n                    $parent.toggleClass('open');\r\n                    var navState = $parent.hasClass('open') ? 'hide' : 'show';\r\n                    $(this).attr('title', navState + ' navigation');\r\n                    setTimeout(function () {\r\n                        console.log('timeout set');\r\n                        $('#menuToggle > span').toggleClass('navClosed').toggleClass('navOpen');\r\n                    }, 200);\r\n                    e.preventDefault();\r\n                });\r\n            });\r\n        }(jQuery));\r\n        //@ sourceURL=pen.js\r\n    </script>\r\n    <!--Quick search auto complete code-->\r\n    <script>\r\n        function ClearSearch() {\r\n            document.getElementById(\"txtQuickSearch\").value = \"\";\r\n        }\r\n\r\n        $(document).ready(function () {\r\n            var results;\r\n            var electionType = document.getElementById(\"hidElectionType\").value;\r\n            var eid = getUrlVars()[\"eid\"];\r\n            var cid;\r\n            var language = 1;\r\n\r\n            if (document.getElementById(\"ddlLanguages\"))\r\n                language = document.getElementById(\"ddlLanguages\").value;\r\n\r\n            if (document.getElementById(\"hidCid\")) {\r\n                cid = document.getElementById(\"hidCid\").value;\r\n            } else {\r\n                cid = getUrlVars()[\"cid\"];\r\n            }\r\n\r\n            if (eid !== undefined && !isNaN(eid) && eid != \"\") {\r\n                results = getValues(ServiceRoot + \"ResultsAjax.svc/GetCandidates?ElectionType=\" + electionType + \"&ElectionID=\" + eid + \"&County=\" + cid + \"&LanguageID=\" + language);\r\n                eid = \"&eid=\" + eid;\r\n            } else {\r\n                results = getValues(ServiceRoot + \"ResultsAjax.svc/GetCandidates?ElectionType=\" + electionType + \"&ElectionID=0&County=\" + cid + \"&LanguageID=\" + language);\r\n                eid = \"\";\r\n            }\r\n            // console.log(results)\r\n            var objListTest = results;\r\n\r\n            if ($('#txtQuickSearch')) {\r\n                $(\"#txtQuickSearch\").autocomplete({\r\n                    appendTo: '#header-search-box',\r\n                    source: objListTest,\r\n                    focus: function (event, ui) {\r\n                        $(\"#txtQuickSearch\").val(ui.item.desc + ' - ' + ui.item.name);\r\n                        return false;\r\n                    },\r\n                    select: function (event, ui) {\r\n                        $(\"#txtQuickSearch\").val(ui.item.desc + ' - ' + ui.item.name);\r\n                        window.location.assign(\"SearchResults.aspx?cid=\" + cid + \"&ID=\" + ui.item.ID + eid);\r\n                        return false;\r\n                    },\r\n                    open: function (event, ui) {\r\n                        if (navigator.userAgent.match(/(iPod|iPhone|iPad)/)) {\r\n                            $('.ui-autocomplete').off('menufocus hover mouseover');\r\n                        }\r\n\r\n                    }\r\n                })\r\n                    .data(\"ui-autocomplete\")._renderItem = function (ul, item) {\r\n\r\n                        return $(\"<li>\")\r\n                            .append(\"<a href='SearchResults.aspx?cid=\" + cid + \"&ID=\" + item.ID + eid + \"'><span class='\" + item.PartyCode + \"'>\" + item.name + \"</span><br><span class='search-description'>\" + item.desc + \"</span></a>\")\r\n                            .appendTo(ul);\r\n                    };\r\n            }\r\n            $('.mtc-icon-position').keypress(function (e) {\r\n                var code = e.keyCode || e.which;\r\n                if (code == 13) { //Enter keycode\r\n                    ShareClick();\r\n                }\r\n\r\n            });\r\n            $('.search-icon-wrapper').keypress(function (e) {\r\n                var code = e.keyCode || e.which;\r\n                if (code == 13) { //Enter keycode\r\n\r\n                    MagClick();\r\n                }\r\n\r\n            });\r\n\r\n        });\r\n    </script>\r\n    <script src=\"/Scripts/HeaderChart.js\"></script>\r\n\r\n    \r\n    <script type=\"text/javascript\">\r\n        function googleTranslateElementInit() {\r\n            var languages = 'hide';\r\n            var userLang = navigator.language || navigator.userLanguage || navigator.languages;\r\n            if (languages !== 'hide' || userLang.substr(0, 2) != 'en') {\r\n                new google.translate.TranslateElement({\r\n                    pageLanguage: 'en',\r\n                    includedLanguages: languages,\r\n                    layout: google.translate.TranslateElement.FloatPosition.TOP_RIGHT,\r\n                    gaTrack: true,\r\n                    gaId: 'UA-98212275-1'\r\n                }, 'google_translate_element');\r\n            }\r\n        }\r\n    </script>\r\n    <script type=\"text/javascript\" src=\"//translate.google.com/translate_a/element.js?cb=googleTranslateElementInit\"></script>\r\n</body>\r\n</html>\r\n"
