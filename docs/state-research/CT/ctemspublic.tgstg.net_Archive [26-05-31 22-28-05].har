            titlebar.className = \"titlebar\";\r\n                titlebar.style.backgroundColor = \"#cccccc\";\r\n                titlebar.style.border = \"1px solid #dddddd\";\r\n                titlebar.innerHTML = \"<span style='float:left'>\" + title + \"</span><a href='javascript:jsMin.closeDialog();' style='float:right;text-decoration:none'><img style='border:0px;' src='assets/images/close.png' alt='Close' title='Close'></a>\";\r\n                divBox.appendChild(titlebar);\r\n                if (movable == undefined) {\r\n                    movable = true\r\n                }\r\n                if (movable) {\r\n                    var cs = this.clientSize();\r\n                    jsMin.draggable(divBox, titlebar, 0, 0, cs.width, cs.height)\r\n                }\r\n            }\r\n            var contentContainer = jsMin.document.createElement(\"div\");\r\n            contentContainer.style.width = width + \"px\";\r\n            contentContainer.style.overflow = \"auto\";\r\n            if (title != undefined && title != null) {\r\n                contentContainer.style.height = (parseInt(height) - 25) + \"px\"\r\n            }\r\n            if (typeof(htmlOrChildObj) == \"object\" && htmlOrChildObj.innerHTML != undefined) {\r\n                contentContainer.appendChild(htmlOrChildObj)\r\n            } else {\r\n                contentContainer.innerHTML = htmlOrChildObj\r\n            }\r\n            divBox.appendChild(contentContainer);\r\n            divBox.style.width = width + \"px\";\r\n            divBox.style.height = height + \"px\";\r\n            var maskDiv;\r\n            if (maskOn == undefined || maskOn) {\r\n                maskDiv = jsMin.maskLayer(true)\r\n            }\r\n            if (isNew) {\r\n                jsMin.document.body.appendChild(divBox)\r\n            }\r\n            divBox.style.display = \"block\";\r\n            if (typeof(jsMinLocalObj.dialogBoxSetup) == \"function\") {\r\n                jsMinLocalObj.dialog