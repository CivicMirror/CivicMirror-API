          "content": {
            "mimeType": "text/html",
            "size": 16912,
            "text": "<!DOCTYPE html>\r\n<html xmlns=\"http://www.w3.org/1999/xhtml\" ng-app=\"ct-enr\">\r\n<head>\r\n    <title>Public Reporting</title>\r\n    <meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\r\n    <link href=\"assets/css/styles.css?v=1.30\" rel=\"stylesheet\" type=\"text/css\" />\r\n    <meta http-equiv=\"Content-Type\" content=\"text/html; charset=iso-8859-1\" />\r\n    <meta name=\"viewport\" content=\"width=device-width\">\r\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\r\n    <script type=\"text/javascript\" src=\"scripts/ng/angular.min.js\"></script>\r\n    <script type=\"text/javascript\" src=\"scripts/ng/angular-route.min.js\"></script>\r\n    <script type=\"text/javascript\" src=\"ng-app/app.js\"></script>\r\n    <script type=\"text/javascript\" src=\"ng-app/app-run.js?v=1.40\"></script>\r\n    <script type=\"text/javascript\" src=\"scripts/jsall.js\"></script>\r\n    <script type=\"text/javascript\" src=\"ng-app/controller/HomeController.js?v=1.30\"></script>\r\n    <script type=\"text/javascript\" src=\"ng-app/controller/RaceController.js?v=1.30\"></script>\r\n    <script type=\"text/javascript\" src=\"ng-app/controller/ReportController.js\"></script>\r\n    <script type=\"text/javascript\" src=\"ng-app/controller/SelectTownController.js?v=1.30\"></script>\r\n    <script type=\"text/javascript\" src=\"ng-app/controller/VoterTurnoutController.js\"></script>\r\n    <script type=\"text/javascript\" src=\"ng-app/controller/districtController.js\"></script>\r\n    <script type=\"text/javascript\" src=\"ng-app/controller/ballotQuestionsController.js\"></script>\r\n</head>\r\n<body>\r\n    <table class=\"maincontainer\" border=\"0\" align=\"center\" cellpadding=\"0\"\r\n           cellspacing=\"0\">\r\n        <tr>\r\n            <td class=\"headerbg\">\r\n                <div class=\"headerseal\"></div>\r\n                <!--<div class=\"training\">\r\n                </div>-->\r\n                <!--<div class=\"headerphoto\"></div>-->\r\n            </td>\r\n        </tr>\r\n        <tr>\r\n            <td align=\"left\" valign=\"top\">\r\n                <table style=\"width:100%\" border=\"0\" cellspacing=\"0\" cellpadding=\"0\">\r\n                    <tr>\r\n                        <td width=\"85%\" height=\"450\" align=\"left\" class=\"borderthreesides\"\r\n                            valign=\"top\">\r\n                            <div>\r\n                                <table style=\"width:100%\" border=\"0\" cellspacing=\"0\" cellpadding=\"0\">\r\n\r\n                                   <!--  <tr>\r\n                                       <td align=\"right\" colspan=\"2\" style=\"padding:10px\">\r\n\t                                            <span class=\"Welcome\">Welcome! <strong>{{userName}} </strong></span> &nbsp;|&nbsp;\r\n\t                                            <a href=\"\" data-ng-click=\"logout();\" style=\"color: #CC6600;font-weight:bold;\">Logout</a>\r\n\t                                            <!--<input type=\"button\"  value=\"Logout\" class=\"button1\" data-ng-click=\"logout();\" />\r\n\t                                        </td>\r\n\t                                    </tr>-->\r\n\t                                <tr>\r\n                                        <td align=\"left\" valign=\"top\" class=\"bgblue\">\r\n                                            <div class=\"electionlabel\">ELECTION CENTER</div>\r\n                                            <div class=\"electionSelect\">Select Election:</div>\r\n                                            <div class=\"electionSelect\" data-ng-show=\"electionsCount > 1 || electionsCount == 0\">\r\n                                                <select name=\"ddlElection\" data-ng-model=\"selectElection\" class=\"txtborder2\" data-ng-change=\"selectElections()\">\r\n                                                    <option value=\"\">-- Select Election --</option>\r\n                                                    <option data-ng-repeat=\"election in elections\" value=\"{{election.ID}}\">{{election.Name}}</option>\r\n                                                </select>\r\n                                            </div>\r\n                                            <div class=\"electionSelect\" data-ng-show=\"electionsCount==1\">\r\n                                                <select name=\"ddlElection\" data-ng-model=\"selectElection\" class=\"txtborder2\" data-ng-change=\"selectElections()\">\r\n                                                    <option data-ng-repeat=\"election in elections\" value=\"{{election.ID}}\">{{election.Name}}</option>\r\n                                                </select>\r\n                                            </div>\r\n                                            <div class=\"electionname\">\r\n                                                <span data-ng-bind=\"electionStatic['DNM']\"></span>\r\n                                            </div>\r\n                                            <div class=\"listofNomiees\"> <a href=\"Reports/LDbyTown.pdf\" target=\"_blank\">Legislative Districts by Town</a></div>\r\n                                        </td>\r\n                                    </tr>\r\n                                    <tr>\r\n                                        <td align=\"center\" valign=\"top\" class=\"bgblue\">\r\n                                            <div class=\"official\">\r\n                                                <span data-ng-if=\"reports.IO=='False'\"><img src=\"assets/images/un_off.gif\" alt=\"\" /></span>\r\n                                                <span style=\"font-weight: bold; font-size: 16px;color:#008000\" data-ng-if=\"reports.IO=='True'\">Official Results</span>\r\n                                            </div>\r\n                                            <div style=\"text-align:right\">\r\n                                                <span style=\"color:red\" data-ng-bind=\"lastUpdatedTime\"></span> <br />\r\n                                                <span style=\"color:green\" data-ng-bind=\"nextUpdatedTime\"></span>\r\n                                            </div>\r\n                                        </td>\r\n                                    </tr>\r\n                                </table>\r\n                                <table style=\"width:100%\" border=\"0\" cellspacing=\"0\" cellpadding=\"0\">\r\n                                    <tr>\r\n                                        <td align=\"center\" valign=\"top\" class=\"bggrey1\">\r\n                                            <table style=\"width:100%\" border=\"0\" align=\"center\" cellpadding=\"0\" cellspacing=\"0\" dwcopytype=\"CopyTableCell\">\r\n                                                <tr>\r\n                                                    <td align=\"center\" valign=\"top\" class=\"bgpagetitle1\">\r\n                                                        <!--<div class=\"menu1\" id=\"dvMainTab\">\r\n                                                            <div class=\"menu6link\" id='mainTab1' data-ng-click=\"switchTab($event, 1)\"></div>\r\n                                                            <div class=\"menu2link\" id='mainTab2' data-ng-click=\"switchTab($event, 2)\"></div>\r\n                                                        </div>-->\r\n                                                        <ul id=\"tabs\">\r\n                                                            <li><a style=\"cursor:pointer\" data-ng-click=\"swtichTabs($event)\" name=\"statewide\" id=\"current\">Statewide</a></li>\r\n                                                            <li><a style=\"cursor:pointer\" data-ng-click=\"swtichTabs($event)\" name=\"selectTown\">Select Town</a></li>\r\n                                                            <li><a style=\"cursor:pointer\" data-ng-click=\"swtichTabs($event)\" name=\"races\">My Races</a></li>\r\n                                                        </ul>\r\n                                                    </td>\r\n                                                </tr>\r\n                                            </table>\r\n                                        </td>\r\n                                    </tr>\r\n                                    <tr>\r\n                                        <td align=\"center\">\r\n                                            <table style=\"width:100%\" border=\"0\" cellspacing=\"0\" cellpadding=\"0\">\r\n                                                <tr>\r\n                                                    <td align=\"left\" class=\"resultssummaryheader\">\r\n                                                        Statewide Reporting Statistics\r\n                                                    </td>\r\n                                                </tr>\r\n                                                <tr>\r\n                                                    <td align=\"center\" valign=\"top\" class=\"bggrey1\">\r\n                                                        <div class=\"colum3\">\r\n                                                            <table style=\"width:100%\" border=\"0\" cellspacing=\"0\" cellpadding=\"3\">\r\n                                                                <tr>\r\n                                                                    <td align=\"right\" width=\"50%\" class=\"borderbottomresults\">\r\n                                                                        <strong>Registered Voters Reported:</strong>\r\n                                                                    </td>\r\n                                                                    <td align=\"left\" width=\"50%\" class=\"borderbottomresults\" id='sw_RO' data-ng-bind=\"electionDynamic.RV\"></td>\r\n                                                                </tr>\r\n                                                            </table>\r\n                                                        </div>\r\n                                                        <div class=\"colum3\">\r\n                                                            <table style=\"width:100%\" border=\"0\" cellspacing=\"0\" cellpadding=\"3\">\r\n                                                                <tr>\r\n                                                                    <td align=\"right\" width=\"50%\" class=\"borderbottomresults\">\r\n                                                                        <strong>Towns Partially Reported: </strong>\r\n                                                                    </td>\r\n                                                                    <td align=\"left\" width=\"50%\" class=\"borderbottomresults\" id='sw_TPR' data-ng-bind=\"electionDynamic.PT\"></td>\r\n                                                                </tr>\r\n                                                            </table>\r\n                                                        </div>\r\n                                                        <div class=\"colum3\">\r\n                                                            <table style=\"width:100%\" border=\"0\" cellspacing=\"0\" cellpadding=\"3\">\r\n                                                                <tr>\r\n                                                                    <td align=\"right\" width=\"50%\" class=\"borderbottomresults\">\r\n                                                                        <strong>Precincts Reported: </strong>\r\n                                                                    </td>\r\n                                                                    <td align=\"left\" width=\"50%\" class=\"borderbottomresults\" id='sw_PR' data-ng-bind=\"electionDynamic.PR\"></td>\r\n                                                                </tr>\r\n                                                            </table>\r\n                                                        </div>\r\n                                                        <div class=\"colum3\">\r\n                                                            <table style=\"width:100%\" border=\"0\" cellspacing=\"0\"\r\n                                                                   cellpadding=\"3\">\r\n                                                                <tr>\r\n                                                                    <td align=\"right\" width=\"50%\" class=\"borderbottomresults\"><strong>Voters Checked Reported:</strong></td>\r\n                                                                    <td align=\"left\" width=\"50%\" class=\"borderbottomresults\" id='sw_BC' data-ng-bind=\"electionDynamic.BC\"></td>\r\n                                                                </tr>\r\n                                                            </table>\r\n                                                        </div>\r\n                                                        <div class=\"colum3\">\r\n                                                            <table style=\"width:100%\" border=\"0\" cellspacing=\"0\"\r\n                                                                   cellpadding=\"3\">\r\n                                                                <tr>\r\n                                                                    <td align=\"right\" width=\"50%\" class=\"borderbottomresults\"><strong>Towns Completely Reported: </strong></td>\r\n                                                                    <td align=\"left\" width=\"50%\" class=\"borderbottomresults\" id='sw_TCR' data-ng-bind=\"electionDynamic.T\"></td>\r\n                                                                </tr>\r\n                                                            </table>\r\n                                                        </div>\r\n                                                        <div class=\"colum3\">\r\n                                                            <table style=\"width:100%\" border=\"0\" cellspacing=\"0\"\r\n                                                                   cellpadding=\"3\">\r\n                                                                <tr>\r\n                                                                    <td align=\"right\" width=\"50%\" class=\"borderbottomresults\"><strong>Voter Turnout (%):</strong></td>\r\n                                                                    <td align=\"left\" width=\"50%\" class=\"borderbottomresults\" id='sw_VT' data-ng-bind=\"electionDynamic.TO\"></td>\r\n                                                                </tr>\r\n                                                            </table>\r\n                                                        </div>\r\n                                                    </td>\r\n                                                </tr>\r\n                                            </table>\r\n                                        </td>\r\n                                    </tr>\r\n                                    <tr id=\"subTabsBar\">\r\n                                        <td align=\"center\" valign=\"top\" class=\"bggrey1\">\r\n                                            <!--<div class=\"menu3\" id=\"dvSubMainTab\">\r\n                                                <div class=\"menu5link\" id='subtab1' data-ng-click=\"switchTab($event, 1)\"></div>\r\n                                                <div class=\"menu4link\" id='subtab2' data-ng-click=\"switchTab($event, 2)\"></div>\r\n                                            </div>-->\r\n                                            <ul id=\"tabs_sub\">\r\n                                                <li><a style=\"cursor:pointer\" data-ng-click=\"swtichTabs($event)\" name=\"home\" id=\"current_sub\">Summary</a></li>\r\n                                                <li><a style=\"cursor:pointer\" data-ng-click=\"swtichTabs($event)\" name=\"voterTurnout\">Voter Turnout</a></li>\r\n                                                <li><a style=\"cursor:pointer\" data-ng-click=\"swtichTabs($event)\" name=\"districts\">Districts</a></li>\r\n                                                <li><a style=\"cursor:pointer\" data-ng-click=\"swtichTabs($event)\" name=\"reports\">Reports</a></li>\r\n\t\t\t\t\t\t\t\t\t\t\t\t<li><a style=\"cursor:pointer\" data-ng-click=\"swtichTabs($event)\" name=\"ballotQuestions\">Ballot Questions</a></li>\r\n                                            </ul>\r\n                                        </td>\r\n                                    </tr>\r\n                                </table>\r\n                            </div>\r\n                            <div ng-view></div>\r\n                        </td>\r\n                    </tr>\r\n                    <tr>\r\n                        <td align=\"left\" valign=\"top\">\r\n                            <img src=\"assets/images/spacer.gif\" width=\"6\" height=\"6\" alt=\"\" />\r\n                        </td>\r\n                    </tr>\r\n                    <tr>\r\n                        <td height=\"10\" align=\"center\" valign=\"middle\" class=\"infotext\">\r\n                            <!--Â© 2016 PCC Technology Inc., All Rights Reserved.-->\r\n                        </td>\r\n                    </tr>\r\n                    <tr>\r\n                        <td align=\"left\" valign=\"top\">&nbsp;</td>\r\n                    </tr>\r\n                </table>\r\n            </td>\r\n        </tr>\r\n    </table>\r\n</body>\r\n</html>"
