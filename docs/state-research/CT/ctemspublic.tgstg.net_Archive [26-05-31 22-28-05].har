\r\n    vertical-align: middle;\r\n    width: 22px;\r\n    height: 22px;\r\n    background: url(\"../images/parties_big_12.png?v=1.14\") 0px 408px;\r\n}\r\n.VFE {\r\n    vertical-align: middle;\r\n    width: 22px;\r\n    height: 22px;\r\n    background: url(\"../images/parties_big_12.png?v=1.14\") 0px 384px;\r\n}\r\n\r\n\r\n.IPP {\r\n    vertical-align: middle;\r\n    width: 22px;\r\n    height: 22px;\r\n    background: url(\"../images/parties_big_12.png?v=1.14\") 0px 362px;\r\n}\r\n\r\n.D {\r\n    vertical-align: middle;\r\n    width: 22px;\r\n    height: 22px;\r\n    background: url(\"../images/parties_big_1.png?v=1.14\") 0px 294px;\r\n}\r\n\r\n.C {\r\n    vertical-align: middle;\r\n    width: 22px;\r\n    height: 22px;\r\n    background: url(\"../images/parties_big_1.png?v=1.14\") 0px 271px;\r\n}\r\n\r\n.IND {\r\n    vertical-align: middle;\r\n    width: 22px;\r\n    height: 22px;\r\n    background: url(\"../images/parties_big_1.png?v=1.14\") 0px 249px;\r\n}\r\n\r\n.NL {\r\n    vertical-align: middle;\r\n    width: 22px;\r\n    height: 22px;\r\n    background: url(\"../images/parties_big_1.png?v=1.14\") 0px 225px;\r\n}\r\n\r\n.INDP {\r\n    vertical-align: middle;\r\n    width: 22px;\r\n    height: 22px;\r\n    background: url(\"../images/parties_big_1.png?v=1.14\") 0px 202px;\r\n}\r\n\r\n.R {\r\n    vertical-align: middle;\r\n    width: 22px;\r\n    height: 22px;\r\n    background: url(\"../images/parties_big_1.png?v=1.14\") 0px 179px;\r\n}\r\n\r\n.G {\r\n    vertical-align: middle;\r\n    width: 22px;\r\n    height: 22px;\r\n    background: url(\"../images/parties_big_1.png?v=1.14\") 0px 156px;\r\n}\r\n\r\n.LI {\r\n    vertical-align: middle;\r\n    width: 22px;\r\n    height: 22px;\r\n    background: url(\"../images/parties_big_1.png?v=1.14\") 0px 133px;\r\n}\r\n\r\n.CGG {\r\n    vertical-align: middle;\r\n    width: 22px;\r\n    height: 22px;\r\n    background: url(\"../images/parties_big_1.png?v=1.14\") 0px 110px;\r\n}\r\n\r\n.O {\r\n    vertical-align: middle;\r\n    width: 22px;\r\n    height: 22px;\r\n    background: url(\"../images/parties_big_1.png?v=1.14\") 0px 88px;\r\n}\r\n\r\n.WF {\r\n    vertical-align: middle;\r\n    width: 22px;\r\n    height: 22px;\r\n    background: url(\"../images/parties_big_1.png?v=1.14\") 0px 67px;\r\n}\r\n\r\n.PC {\r\n    vertical-align: middle;\r\n    width: 22px;\r\n    height: 22px;\r\n    background: url(\"../images/parties_big_1.png?v=1.14\") 0px 0px;\r\n}\r\n\r\n.WI {\r\n    vertical-align: middle;\r\n    width: 22px;\r\n    height: 22px;\r\n    background: url(\"../images/parties_big_1.png?v=1.14\") 0px 318px;\r\n}\r\n.GFCT{\r\n    vertical-align: middle;\r\n    width: 22px;\r\n    height: 22px;\r\n    background: url(\"../images/parties_big_1.png?v=1.14\") 0px 43px;\r\n}\r\n.ACL{\r\n    vertical-align: middle;\r\n    width: 22px;\r\n    height: 22px;\r\n    background: url(\"../images/parties_big_1.png?v=1.14\") 0px 22px;\r\n}\r\n\r\n/* styles for parties codes beside candidate names*/\r\n\r\n.maincontainer {\r\n    width: 95%;\r\n}\r\n\r\n/* styles for input, textarea, select */\r\n\r\n.txtborder {\r\n    font-family: Arial, Helvetica, sans-serif;\r\n    font-size: 12px;\r\n    border: 1px solid #666666;\r\n    background-color: #F2F2F2;\r\n}\r\n\r\n.training {\r\n    position: absolute;\r\n    left: 45%;\r\n    background: url(../images/training.gif) no-repeat;  width:150px; height:20px;\r\n}\r\n.button {\r\n    font-family: Arial, Helvetica, sans-serif;\r\n    font-size: 12px;\r\n    color: #FFFFFF;\r\n    font-weight: bold;\r\n    border: 1px solid #1A5786;\r\n    background-color: #5688BD;\r\n    padding: 1px 10px;\r\n    background-image: url(../images/button_bg2.gif);\r\n    background-repeat: repeat-x;\r\n    -webkit-border-radius: 5px;\r\n    -moz-border-radius: 5px;\r\n    border-radius: 5px;\r\n}\r\n\r\n.button1 {\r\n    background: none repeat scroll 0 0 #186194;\r\n    border: 0 none;\r\n    border-radius: 14px;\r\n    color: #fff;\r\n    cursor: pointer;\r\n    font-family: Arial,Helvetica,sans-serif;\r\n    font-size: 13px;\r\n    font-weight: bold;\r\n    padding: 4px 16px 4px 16px;\r\n}\r\n\r\n.headerseal {\r\n    float: left;\r\n    background-image: url(../images/logo_b.gif);\r\n    width: 454px;\r\n    height: 61px;\r\n    background-repeat: no-repeat;\r\n    margin-left: 10px;\r\n    margin-top: 12px;\r\n    margin-bottom: 12px;\r\n}\r\n\r\n.headerphoto {\r\n    float: right;\r\n    background-image: url(../images/secretary.gif);\r\n    width: 90px;\r\n    height: 86px;\r\n    background-repeat: no-repeat;\r\n}\r\n\r\n.arrowup {\r\n    float: left;\r\n    background-image: url(../images/arrow_up.gif);\r\n    width: 7px;\r\n    height: 12px;\r\n    background-repeat: no-repeat;\r\n    margin: 4px 0 0 6px;\r\n}\r\n\r\n/* styles for fonts sizes */\r\n\r\n.font9 {\r\n    font-family: Verdana, Arial, Helvetica, sans-serif;\r\n    font-size: 9px;\r\n    color: #000000;\r\n}\r\n\r\n.font9white {\r\n    font-family: Verdana, Arial, Helvetica, sans-serif;\r\n    font-size: 9px;\r\n    color: #FFFFFF;\r\n}\r\n\r\n.font10 {\r\n    font-family: Verdana, Arial, Helvetica, sans-serif;\r\n    font-size: 10px;\r\n    color: #000000;\r\n}\r\n\r\n.font10white {\r\n    font-family: Verdana, Arial, Helvetica, sans-serif;\r\n    font-size: 10px;\r\n    color: #FFFFFF;\r\n}\r\n\r\n.fontred {\r\n    font-family: Verdana, Arial, Helvetica, sans-serif;\r\n    font-size: 11px;\r\n    color: #FF0000;\r\n}\r\n\r\n.font11 {\r\n    font-family: Verdana, Arial, Helvetica, sans-serif;\r\n    font-size: 11px;\r\n    color: #000000;\r\n}\r\n\r\n\r\n\r\n.fontcontent {\r\n    font-family: Verdana, Arial, Helvetica, sans-serif;\r\n    font-size: 11px;\r\n    color: #333333;\r\n    line-height: 18px;\r\n    text-align: justify;\r\n}\r\n\r\n.fontcontentheader {\r\n    font-family: Verdana, Arial, Helvetica, sans-serif;\r\n    font-size: 12px;\r\n    font-weight: bold;\r\n    border-bottom: 1px dotted #006699;\r\n    color: #006699;\r\n}\r\n\r\n\r\n.font11white {\r\n    font-family: Verdana, Arial, Helvetica, sans-serif;\r\n    font-size: 11px;\r\n    color: #FFFFFF;\r\n}\r\n\r\n.font12 {\r\n    font-family: Verdana, Arial, Helvetica, sans-serif;\r\n    font-size: 12px;\r\n    color: #000000;\r\n}\r\n\r\n.font11bold {\r\n    font-family: Verdana, Arial, Helvetica, sans-serif;\r\n    font-size: 11px;\r\n    color: #000000;\r\n    font-weight: bold;\r\n}\r\n\r\n\r\n.font12bold {\r\n    font-family: Verdana, Arial, Helvetica, sans-serif;\r\n    font-size: 12px;\r\n    color: #000000;\r\n    font-weight: bold;\r\n}\r\n\r\n\r\n.font12white {\r\n    font-family: Verdana, Arial, Helvetica, sans-serif;\r\n    font-size: 12px;\r\n    color: #FFFFFF;\r\n}\r\n\r\n.font16 {\r\n    font-family: Verdana, Arial, Helvetica, sans-serif;\r\n    font-size: 16px;\r\n    color: #000000;\r\n}\r\n\r\n\r\n.font11orange {\r\n    font-family: Verdana, Arial, Helvetica, sans-serif;\r\n    font-size: 11px;\r\n    color: #B6492C;\r\n    font-weight: bold;\r\n}\r\n\r\n.font12orange {\r\n    font-family: Verdana, Arial, Helvetica, sans-serif;\r\n    font-size: 12px;\r\n    color: #B6492C;\r\n    font-weight: bold;\r\n}\r\n\r\n.fontgreen {\r\n    font-family: Verdana, Arial, Helvetica, sans-serif;\r\n    font-size: 15px;\r\n    color: #006600;\r\n    font-weight: bold;\r\n}\r\n\r\n\r\n.infotext {\r\n    font-family: Verdana, Arial, Helvetica, sans-serif;\r\n    font-size: 10px;\r\n    color: #666666;\r\n}\r\n\r\n.titlesmall {\r\n    font-family: Arial, Helvetica, sans-serif;\r\n    font-size: 11px;\r\n    color: #666666;\r\n    padding: 3px;\r\n    background-color: #e5e5e5;\r\n    font-weight: bold;\r\n}\r\n\r\n\r\n\r\n/* styles for bgcolor */\r\n\r\n.bgwhite {\r\n    background-color: #FFFFFF;\r\n}\r\n\r\n.bggrey0 {\r\n    background-color: #f2f2f2;\r\n}\r\n\r\n.bggrey1 {\r\n    background-color: #E2E2E2;\r\n}\r\n\r\n\r\n.bggrey {\r\n    background-color: #CCCCCC;\r\n    font-size: 12px;\r\n    font-family: Verdana, Arial, Helvetica, sans-serif;\r\n}\r\n\r\n.bgblack {\r\n    background-color: #000000;\r\n}\r\n\r\n.bgpagetitle {\r\n    background-color: #FAFDFF;\r\n    border-right: 1px solid #6595C0;\r\n}\r\n\r\n.bgpagetitle1 {\r\n    background-color: #6595C0;\r\n}\r\n\r\n.bgpagetitle2 {\r\n    background-color: #E8F3FF;\r\n}\r\n\r\n\r\n.bgpeach2 {\r\n    background-color: #A3C6EB;\r\n}\r\n\r\n.border {\r\n    border: 1px solid #cccccc;\r\n}\r\n\r\n.borderbottom {\r\n    border-bottom: 1px solid #e4e4e4;\r\n}\r\n\r\n.borderbottomresults {\r\n    border-bottom: 1px solid #fff;\r\n}\r\n\r\n.border1 {\r\n    border: 1px solid #cccccc;\r\n}\r\n\r\n.bgblue {\r\n    background-color: #EDF7FF;\r\n    height: 50px;\r\n}\r\n\r\n.bgbluedark {\r\n    background-color: #BBDCF9;\r\n}\r\n\r\n\r\n.borderrightgrey {\r\n    border-right: 1px solid #CCCCCC;\r\n}\r\n\r\n.tableheadergrey {\r\n    background-color: #cccccc;\r\n    font-family: Verdana, Arial, Helvetica, sans-serif;\r\n    font-size: 12px;\r\n    color: #000000;\r\n    font-weight: bold;\r\n}\r\n\r\n.box {\r\n    float: center;\r\n    background-color: #F5F5f5;\r\n    color: #006600;\r\n    font-family: Verdana, Arial, Helvetica, sans-serif;\r\n    font-size: 15px;\r\n    font-weight: bold;\r\n    border: 2px dotted #666666;\r\n    padding: 20px;\r\n}\r\n\r\n\r\n.boxred {\r\n    float: center;\r\n    background-color: #F5F5f5;\r\n    color: #CC0000;\r\n    font-family: Verdana, Arial, Helvetica, sans-serif;\r\n    font-size: 15px;\r\n    font-weight: bold;\r\n    border: 2px dotted #666666;\r\n    padding: 20px;\r\n}\r\n\r\n\r\n.snip {\r\n    float: center;\r\n    padding: 1px;\r\n    color: #C9A423;\r\n    border-style: dotted;\r\n    border-width: 2px;\r\n    padding-right: 4px;\r\n    border-color: #191919;\r\n    background-color: #4B4B4B;\r\n    width: 95;\r\n    font-size: 11pt;\r\n    font-weight: 700;\r\n    text-align: center;\r\n}\r\n\r\n\r\n\r\n.tdgradient {\r\n    background: #BAC4BB;\r\n    filter: alpha(opacity=20, finishopacity=100, Style=1, startx=0, starty=10, finishx=0, finishy=50);\r\n}\r\n\r\n/* Style for default text links*/\r\n\r\na, a:link, a:active, a:vlink {\r\n    text-decoration: underline;\r\n    font: normal 11px;\r\n    color: #000000;\r\n}\r\n\r\n    a:hover {\r\n        text-decoration: none;\r\n        font: normal 11px;\r\n        color: #000000;\r\n    }\r\n\r\n    /* Style for orange links*/\r\n\r\n\r\n    /* style on the enlarge view */\r\n    A.linkorange:link {\r\n        color: #003366;\r\n        font-family: verdana;\r\n        font-size: 10px;\r\n        text-decoration: none;\r\n        font-weight: bold;\r\n    }\r\n\r\n    A.linkorange:visited {\r\n        color: #003366;\r\n        font-family: verdana;\r\n        font-size: 10px;\r\n        text-decoration: none;\r\n        font-weight: bold;\r\n    }\r\n\r\n    A.linkorange:active {\r\n        color: #003366;\r\n        font-family: verdana;\r\n        font-size: 10px;\r\n        text-decoration: none;\r\n        font-weight: bold;\r\n    }\r\n\r\n    A.linkorange:hover {\r\n        color: #cc3300;\r\n        font-family: verdana;\r\n        font-size: 10px;\r\n        text-decoration: none;\r\n        font-weight: bold;\r\n    }\r\n\r\n\r\n    /* style for the left menu main links*/\r\n    A.linkleftmenu:link {\r\n        color: #B6492C;\r\n        font-family: Verdana;\r\n        font-size: 11px;\r\n        text-decoration: none;\r\n        text-transform: uppercase;\r\n        font-weight: bold;\r\n    }\r\n\r\n    A.linkleftmenu:visited {\r\n        color: #B6492C;\r\n        font-family: Verdana;\r\n        font-size: 11px;\r\n        text-decoration: none;\r\n        text-transform: uppercase;\r\n        font-weight: bold;\r\n    }\r\n\r\n    A.linkleftmenu:active {\r\n        color: #B6492C;\r\n        font-family: Verdana;\r\n        font-size: 11px;\r\n        text-decoration: none;\r\n        text-transform: uppercase;\r\n        font-weight: bold;\r\n    }\r\n\r\n    A.linkleftmenu:hover {\r\n        color: #B6492C;\r\n        font-family: Verdana;\r\n        font-size: 11px;\r\n        text-decoration: underline;\r\n        text-transform: uppercase;\r\n        font-weight: bold;\r\n    }\r\n\r\n\r\n    /* style for the left menu 3 level links*/\r\n    A.linkleftmenu3:link {\r\n        color: #B6492C;\r\n        font-family: Verdana;\r\n        font-size: 11px;\r\n        text-decoration: none;\r\n        font-weight: nornal;\r\n    }\r\n\r\n    A.linkleftmenu3:visited {\r\n        color: #B6492C;\r\n        font-family: Verdana;\r\n        font-size: 11px;\r\n        text-decoration: none;\r\n        font-weight: nornal;\r\n    }\r\n\r\n    A.linkleftmenu3:active {\r\n        color: #B6492C;\r\n        font-family: Verdana;\r\n        font-size: 11px;\r\n        text-decoration: none;\r\n        font-weight: nornal;\r\n    }\r\n\r\n    A.linkleftmenu3:hover {\r\n        color: #B6492C;\r\n        font-family: Verdana;\r\n        font-size: 11px;\r\n        text-decoration: underline;\r\n        font-weight: nornal;\r\n    }\r\n\r\n\r\n    /* style for the left menu sub links*/\r\n    A.linkleftsubmenu:link {\r\n        color: #003366;\r\n        font-family: Verdana;\r\n        font-size: 11px;\r\n        text-decoration: none;\r\n        font-weight: normal;\r\n    }\r\n\r\n    A.linkleftsubmenu:visited {\r\n        color: #003366;\r\n        font-family: Verdana;\r\n        font-size: 11px;\r\n        text-decoration: none;\r\n        font-weight: normal;\r\n    }\r\n\r\n    A.linkleftsubmenu:active {\r\n        color: #003366;\r\n        font-family: Verdana;\r\n        font-size: 11px;\r\n        text-decoration: none;\r\n        font-weight: normal;\r\n    }\r\n\r\n    A.linkleftsubmenu:hover {\r\n        color: #003366;\r\n        font-family: Verdana;\r\n        font-size: 11px;\r\n        text-decoration: underline;\r\n        font-weight: normal;\r\n    }\r\n\r\n\r\n\r\n\r\n    /* style for the navigation*/\r\n    A.linksnavigation:link {\r\n        color: #003366;\r\n        font-family: Verdana;\r\n        font-size: 12px;\r\n        text-decoration: none;\r\n        font-weight: bold;\r\n        background-color: #EEEEEE;\r\n        padding-left: 7px;\r\n        padding-right: 7px;\r\n    }\r\n\r\n    A.linksnavigation:visited {\r\n        color: #003366;\r\n        font-family: Verdana;\r\n        font-size: 12px;\r\n        text-decoration: none;\r\n        font-weight: bold;\r\n        background-color: #EEEEEE;\r\n        padding-left: 7px;\r\n        padding-right: 7px;\r\n    }\r\n\r\n    A.linksnavigation:active {\r\n        color: #003366;\r\n        font-family: Verdana;\r\n        font-size: 12px;\r\n        text-decoration: none;\r\n        font-weight: bold;\r\n        background-color: #EEEEEE;\r\n        padding-left: 7px;\r\n        padding-right: 7px;\r\n    }\r\n\r\n    A.linksnavigation:hover {\r\n        color: #B6492C;\r\n        font-family: Verdana;\r\n        font-size: 12px;\r\n        text-decoration: underline;\r\n        font-weight: bold;\r\n        background-color: #EEEEEE;\r\n        padding-left: 7px;\r\n        padding-right: 7px;\r\n    }\r\n\r\n/* style for the navigation activated no.*/\r\n.linksnavigationactive {\r\n    color: #FFFFCC;\r\n    font-family: Verdana;\r\n    font-size: 12px;\r\n    text-decoration: none;\r\n    font-weight: bold;\r\n    background-color: #5688BD;\r\n    padding-left: 7px;\r\n    padding-right: 7px;\r\n}\r\n\r\n.remaindertitle {\r\n    font-family: Verdana, Arial, Helvetica, sans-serif;\r\n    font-size: 15px;\r\n    color: #325C8F;\r\n    font-weight: bold;\r\n    padding-left: 5px;\r\n    border-bottom: 2px solid #6595C0;\r\n}\r\n\r\n.boxred {\r\n    float: center;\r\n    background-color: #F5F5f5;\r\n    color: #CC0000;\r\n    font-family: Verdana, Arial, Helvetica, sans-serif;\r\n    font-size: 13px;\r\n    font-weight: bold;\r\n    border: 2px dotted #666666;\r\n    padding: 20px;\r\n    line-height: 30px;\r\n}\r\n\r\n.boxgreen {\r\n    float: center;\r\n    background-color: #F5F5f5;\r\n    color: #006633;\r\n    font-family: Verdana, Arial, Helvetica, sans-serif;\r\n    font-size: 13px;\r\n    font-weight: bold;\r\n    border: 2px dotted #666666;\r\n    padding: 20px;\r\n    line-height: 30px;\r\n}\r\n\r\n.boxred1 {\r\n    float: center;\r\n    background-color: #F5F5f5;\r\n    color: #CC0000;\r\n    font-family: Verdana, Arial, Helvetica, sans-serif;\r\n    font-size: 11px;\r\n    font-weight: bold;\r\n    border: 2px dotted #666666;\r\n    padding: 15px;\r\n}\r\n\r\n.boxgreen1 {\r\n    float: center;\r\n    background-color: #F5F5f5;\r\n    color: #003366;\r\n    font-family: Verdana, Arial, Helvetica, sans-serif;\r\n    font-size: 11px;\r\n    font-weight: bold;\r\n    border: 2px dotted #666666;\r\n    padding: 15px;\r\n}\r\n\r\n.combo1 {\r\n    font-family: Verdana, Arial, Helvetica, sans-serif;\r\n    font-size: 12px;\r\n    border: 1px solid #666666;\r\n    background-color: #FFFFFF;\r\n    position: absolute;\r\n    margin: 0px;\r\n    padding: 0px 0px;\r\n    float: left;\r\n    width: 150px;\r\n    height: 100px;\r\n    overflow: auto;\r\n}\r\n\r\n/*  styles adder after 26 nov 07*/\r\n\r\n\r\n\r\n/* style for the left menu sub links*/\r\nA.linkleftsubmenuactive:link {\r\n    color: #B6492C;\r\n    font-family: Verdana;\r\n    font-size: 11px;\r\n    text-decoration: none;\r\n    font-weight: normal;\r\n}\r\n\r\nA.linkleftsubmenuactive:visited {\r\n    color: #B6492C;\r\n    font-family: Verdana;\r\n    font-size: 11px;\r\n    text-decoration: none;\r\n    font-weight: normal;\r\n}\r\n\r\nA.linkleftsubmenuactive:active {\r\n    color: #B6492C;\r\n    font-family: Verdana;\r\n    font-size: 11px;\r\n    text-decoration: none;\r\n    font-weight: normal;\r\n}\r\n\r\nA.linkleftsubmenuactive:hover {\r\n    color: #B6492C;\r\n    font-family: Verdana;\r\n    font-size: 11px;\r\n    text-decoration: underline;\r\n    font-weight: normal;\r\n}\r\n\r\n\r\n\r\n.border2 {\r\n    background-color: #cccccc;\r\n}\r\n\r\n.boxredbig {\r\n    float: center;\r\n    background-color: #F5F5f5;\r\n    color: #CC0000;\r\n    font-family: Verdana, Arial, Helvetica, sans-serif;\r\n    font-size: 18px;\r\n    font-weight: bold;\r\n    line-height: 30px;\r\n}\r\n\r\n\r\n\r\n.boxgreenbig {\r\n    float: center;\r\n    background-color: #F5F5f5;\r\n    color: #006633;\r\n    font-family: Verdana, Arial, Helvetica, sans-serif;\r\n    font-size: 18px;\r\n    font-weight: bold;\r\n    line-height: 30px;\r\n}\r\n\r\n\r\n\r\n\r\n/*  styles for reporting screen  */\r\n\r\n.borderthreesides {\r\n    border-bottom: 2px solid #6595C0;\r\n    border-left: 2px solid #6595C0;\r\n    border-right: 2px solid #6595C0;\r\n}\r\n\r\n.boxred2 {\r\n    float: center;\r\n    background-color: #FFFFFF;\r\n    color: #154D7D;\r\n    font-family: Arial, Helvetica, sans-serif;\r\n    font-size: 18px;\r\n    font-weight: bold;\r\n    padding: 5px;\r\n    text-align: left;\r\n    border-bottom: 1px solid #eee;\r\n}\r\n\r\n.bordertitle {\r\n    border-bottom: 1px solid #666666;\r\n}\r\n\r\n.progressbar {\r\n    height: 12px;\r\n    background-color: #FF9600;\r\n}\r\n\r\n.progressbar1 {\r\n    height: 8px;\r\n    background-color: #FFF;\r\n}\r\n\r\n.borderpro {\r\n    border: 1px solid #666666;\r\n}\r\n\r\n\r\n.headertext {\r\n    font-family: Arial, Helvetica, sans-serif;\r\n    font-size: 20px;\r\n    color: #333333;\r\n    font-weight: bold;\r\n    padding: 10px 10px;\r\n}\r\n\r\n.headerbg {\r\n    background: #1c588c url(../images/headerbg.gif) repeat-x;\r\n    height: 61px;\r\n}\r\n\r\n\r\n.electionbanner TD {\r\n    font-size: 11px;\r\n    font-family: Arial, Helvetica, sans-serif;\r\n    color: #285377;\r\n}\r\n\r\n\r\n.electionlabel {\r\n    float: left;\r\n    margin-left: 15px;\r\n    vertical-align: top;\r\n    font-family: Arial, Helvetica, sans-serif;\r\n    font-size: 30px;\r\n    color: #549fcc;\r\n    font-weight: bold;\r\n}\r\n\r\n.titleunofficial {\r\n    color: #6595C0;\r\n    font-weight: bold;\r\n    padding: 3px;\r\n    text-align: center;\r\n    float: right;\r\n    font-size: 12px;\r\n}\r\n\r\n.resultssummarytitle {\r\n    text-transform: uppercase;\r\n    font: 18px Arial, Helvetica, sans-serif;\r\n    font-weight: bold;\r\n    color: #154D7D;\r\n}\r\n\r\n.resultsOfficetitle {\r\n    text-transform: uppercase;\r\n    font: 14px Arial, Helvetica, sans-serif;\r\n    font-weight: bold;\r\n    color: #154D7D;\r\n}\r\n.resultssummarytitle2 {\r\n    font: 18px Arial, Helvetica, sans-serif;\r\n    font-weight: bold;\r\n    color: #154D7D;\r\n    border-bottom: 1px solid #dddddd;\r\n}\r\n\r\n.resultssummarytitle2_1 {\r\n    font: 16px Arial, Helvetica, sans-serif;\r\n    font-weight: bold;\r\n    color: #154D7D;\r\n    border-bottom: 1px solid #dddddd;\r\n}\r\n\r\n.resultssummarytitle2_2 {\r\n    font: 12px Arial, Helvetica, sans-serif;\r\n    font-weight: bold;\r\n    color: #CC6600;\r\n    /*height:19px;*/\r\n    border-bottom: 1px solid #dddddd;\r\n}\r\n.resultssummarytitleForRaces {\r\n    text-transform: uppercase;\r\n    font: 18px Arial, Helvetica, sans-serif;\r\n    font-weight: bold;\r\n    color: #CC6600;\r\n}\r\n    .resultssummarytitle2_2 span {\r\n        color: #1C588C;\r\n    }\r\n\r\n    .resultssummarytitle2_2 a: {\r\n        color: #CC6600;\r\n    }\r\n\r\n        .resultssummarytitle2_2 a:link {\r\n            text-decoration: none;\r\n            color: #CC6600;\r\n        }\r\n        /* unvisited link */\r\n        .resultssummarytitle2_2 a:visited {\r\n            color: #CC6600;\r\n            text-decoration: none;\r\n        }\r\n        /* visited link */\r\n        .resultssummarytitle2_2 a:hover {\r\n            color: #CC6600;\r\n            text-decoration: none;\r\n        }\r\n        /* mouse over link */\r\n        .resultssummarytitle2_2 a:active {\r\n            color: #CC6600;\r\n            text-decoration: none;\r\n        }\r\n\r\n.resultssummarytitle3 {\r\n    font: 18px Arial, Helvetica, sans-serif;\r\n    font-weight: bold;\r\n    color: #cc3300;\r\n    /*border-bottom: 1px solid #dddddd;*/\r\n}\r\n\r\n.resultssummaryheader {\r\n    background-color: #DFEDFE;\r\n    border-right: 1px solid #DADADA;\r\n    border-bottom: 2px solid #FFFFFF;\r\n    padding: 8px;\r\n    text-transform: uppercase;\r\n    font-weight: bold;\r\n}\r\n\r\n.resultssummaryvalues {\r\n    background-color: #F2F2F2;\r\n    border-right: 1px solid #DADADA;\r\n    border-bottom: 1px solid #DADADA;\r\n    padding: 8px 12px;\r\n}\r\n\r\n.resultsvalues {\r\n    background-color: #F2F2F2;\r\n    color: #225E91;\r\n    border-right: 1px solid #DADADA;\r\n    border-bottom: 1px solid #DADADA;\r\n    padding: 8px 12px;\r\n}\r\n\r\n.txtborder2 {\r\n    background: none repeat scroll 0 0 #fff;\r\n    border: 1px solid #c7c6b1;\r\n    border-radius: 3px;\r\n    color: #333;\r\n    padding: 3px;\r\n}\r\n\r\n.note {\r\n    color: #999;\r\n}\r\n\r\n/*  styles for count of parties  */\r\n\r\n.partydem {\r\n    background-image: url(../images/party_dem.gif);\r\n    background-repeat: no-repeat;\r\n    background-position: left top;\r\n    color: #0286AD;\r\n    padding-left: 20px;\r\n    font-weight: bold;\r\n    font-size: 13px;\r\n    line-height: 22px; /*float: left;*/\r\n}\r\n\r\n.partydembig {\r\n    background-image: url(../images/party_dem_big.gif);\r\n    height: 23px;\r\n    background-repeat: no-repeat;\r\n    background-position: left;\r\n    color: #0286AD;\r\n    padding-left: 20px;\r\n    font-weight: bold;\r\n    font-size: 13px;\r\n    line-height: 22px;\r\n    float: left;\r\n}\r\n\r\n.partyrep {\r\n    background-image: url(../images/party_rep.gif);\r\n    background-repeat: no-repeat;\r\n    background-position: left top;\r\n    color: #C90102;\r\n    padding-left: 20px;\r\n    font-weight: bold;\r\n    font-size: 13px;\r\n    line-height: 22px; /*float: left;*/\r\n}\r\n\r\n.partyrepbig {\r\n    background-image: url(../images/party_rep_big.gif);\r\n    height: 23px;\r\n    background-repeat: no-repeat;\r\n    background-position: left;\r\n    color: #C90102;\r\n    padding-left: 30px;\r\n    font-weight: bold;\r\n    font-size: 13px;\r\n    line-height: 22px;\r\n    float: left;\r\n}\r\n\r\n\r\n.colorhighlight {\r\n    color: #CC6600;\r\n}\r\n\r\n.colorhighlightForRace {\r\n    color: #CC6600;\r\n}\r\n  \r\n\r\n\r\n/*------------------POPUPS------------------------*/\r\n#fade {\r\n    display: none;\r\n    background: #000;\r\n    position: fixed;\r\n    left: 0;\r\n    top: 0;\r\n    z-index: 10;\r\n    width: 100%;\r\n    height: 100%;\r\n    opacity: .80;\r\n    z-index: 9999;\r\n}\r\n\r\n.popup_block {\r\n    display: none;\r\n    background: #fff;\r\n    padding: 5px;\r\n    border: 5px solid #fff;\r\n    float: left;\r\n    font-size: 12px;\r\n    position: fixed;\r\n    top: 50%;\r\n    left: 50%;\r\n    z-index: 99999;\r\n    -webkit-box-shadow: 0px 0px 20px #000;\r\n    -moz-box-shadow: 0px 0px 20px #000;\r\n    box-shadow: 0px 0px 20px #000;\r\n    -webkit-border-radius: 10px;\r\n    -moz-border-radius: 10px;\r\n    border-radius: 10px;\r\n}\r\n\r\n.popup p {\r\n    padding: 5px 10px;\r\n    margin: 5px 0;\r\n}\r\n/*--Making IE6 Understand Fixed Positioning--*/\r\n\r\n*html #fade {\r\n    position: absolute;\r\n}\r\n\r\n*html .popup_block {\r\n    position: absolute;\r\n}\r\n\r\n\r\n\r\n#but_blue {\r\n    float: left;\r\n    font-family: arial;\r\n    font-size: 12px;\r\n    margin-left: 5px;\r\n}\r\n\r\n    #but_blue li {\r\n        list-style: none;\r\n    }\r\n\r\n    #but_blue a {\r\n        float: left;\r\n        background: url(../images/buton_bgleft.gif) no-repeat left top;\r\n        font-weight: normal;\r\n        margin: 0;\r\n        padding: 0 0 0 7px;\r\n        text-decoration: none;\r\n    }\r\n\r\n        #but_blue a span {\r\n            float: left;\r\n            display: block;\r\n            background: url(../images/buton_bgright.gif) no-repeat right top;\r\n            padding: 3px 12px 3px 5px;\r\n            color: #fff;\r\n        }\r\n        /* Commented Backslash Hack hides rule from IE5-Mac \\*/\r\n        #but_blue a span {\r\n            float: none;\r\n        }\r\n/*#but_blue a:hover span\r\n{\r\n    float: left;\r\n    font-family: arial;\r\n    font-size: 12px;\r\n    margin: auto;\r\n}\r\n\r\n*/\r\n\r\n.menu1 {\r\n    background-image: url(../images/tabs_03.gif);\r\n    background-repeat: no-repeat;\r\n    width: 494px;\r\n    height: 35px;\r\n    margin: auto;\r\n}\r\n\r\n.menu1link {\r\n    float: left;\r\n    width: 160px;\r\n    height: 35px;\r\n    cursor: pointer;\r\n}\r\n\r\n.menu2 {\r\n    background-image: url(../images/tabs_07.gif);\r\n    background-repeat: no-repeat;\r\n    width: 494px;\r\n    height: 35px;\r\n    margin: auto;\r\n}\r\n\r\n.menu2link {\r\n    float: right;\r\n    width: 160px;\r\n    height: 35px;\r\n    cursor: pointer;\r\n}\r\n\r\n.menu2alink {\r\n    float: left;\r\n    width: 160px;\r\n    height: 35px;\r\n    cursor: pointer;\r\n}\r\n\r\n.menu6 {\r\n    background-image: url(../images/tabs_07_2.gif);\r\n    background-repeat: no-repeat;\r\n    width: 494px;\r\n    height: 35px;\r\n    margin: auto;\r\n}\r\n\r\n.menu6link {\r\n    float: right;\r\n    width: 160px;\r\n    height: 35px;\r\n    cursor: pointer;\r\n}\r\n\r\n.menu3 {\r\n    background-image: url(../images/tabs_06.gif);\r\n    background-repeat: no-repeat;\r\n    width: 619px;\r\n    height: 40px;\r\n    margin: auto;\r\n}\r\n\r\n.menu4 {\r\n    background-image: url(../images/tabs_08.gif);\r\n    background-repeat: no-repeat;\r\n    width: 619px;\r\n    height: 40px;\r\n    margin: auto;\r\n}\r\n\r\n.menu5 {\r\n    background-image: url(../images/tabs_09.gif);\r\n    background-repeat: no-repeat;\r\n    width: 619px;\r\n    height: 40px;\r\n    margin: auto;\r\n}\r\n\r\n.menu3link {\r\n    float: left;\r\n    width: 206px;\r\n    height: 40px;\r\n    cursor: pointer;\r\n}\r\n\r\n.menu4link {\r\n    float: right;\r\n    width: 206px;\r\n    height: 40px;\r\n    cursor: pointer;\r\n}\