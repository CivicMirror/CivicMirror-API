          "content": {
            "mimeType": "application/javascript",
            "size": 1631,
            "text": "var enrApp = angular.module(\"ct-enr\", ['ngRoute']);\nenrApp.config(function ($routeProvider, $httpProvider) {\n    $httpProvider.defaults.cache = false;\n    if (!$httpProvider.defaults.headers.get) {\n        $httpProvider.defaults.headers.get = {};\n    }\n    //// disable IE ajax request caching\n    $httpProvider.defaults.headers.get['If-Modified-Since'] = 'Mon, 26 Jul 1997 05:00:00 GMT';\n\n\t$routeProvider.when('/home', {\n\t    templateUrl: 'ng-app/partial/Home.html',\n\t\tcontroller: 'HomeController',\n\t\treloadOnSearch: false\n\t}).when('/voterTurnout', {\n\t    templateUrl: 'ng-app/partial/VoterTurnout.html',\n\t    controller: 'VoterTurnoutController',\n\t    reloadOnSearch: false\n\t}).when('/reports', {\n\t    templateUrl: 'ng-app/partial/Report.html',\n\t    controller: 'ReportController',\n\t    reloadOnSearch: false\n\t}).when('/selectTown', {\n\t    templateUrl: 'ng-app/partial/SelectTown.html',\n\t    controller: 'SelectTownController',\n\t    reloadOnSearch: false\n\t}).when('/races', {\n\t    templateUrl: 'ng-app/partial/MyRace.html',\n\t    controller: 'RaceController',\n\t    reloadOnSearch: false\n\t}).when('/districts', {\n\t    templateUrl: 'ng-app/partial/Districts.html',\n\t    controller: 'districtController',\n\t    reloadOnSearch: false\n    }).when('/ballotQuestions', {\n        templateUrl: 'ng-app/partial/BallotQuestions.html',\n        controller: 'ballotQuestionsController',\n        reloadOnSearch: false\n    }).when('/candidateGrouping', {\n        templateUrl: 'ng-app/partial/candidateGrouping.html',\n        controller: 'candidateGroupingController',\n        reloadOnSearch: false\n    }).otherwise({\n\t\tredirectTo: '/home'\n\t});\n});"
