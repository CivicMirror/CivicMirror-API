          "content": {
            "mimeType": "text/html",
            "size": 5885,
            "text": "<div style=\"padding:10px;\">\n    <div id=\"dvTown_summary\" class=\"colum2\">\n        <table width=\"100%\" cellspacing=\"0\" cellpadding=\"0\">\n            <tbody>\n                <tr>\n                    <td width=\"100%\" class=\"resultssummarytitle2_1\" height=\"30px\">\n                        <div>\n                            Select Your County &nbsp; &nbsp;\n                            <select id=\"scounty\" name=\"scounty\" style=\"width:150px\" data-ng-options=\"key as value for (key,value) in counties track by key\"\n                                    data-ng-change=\"filltowns()\" ng-model=\"selectedCounty\">\n                                <option value=\"\">-- Select County --</option>\n                            </select>\n                        </div>\n                    </td>\n                </tr>\n                <tr>\n                    <td width=\"100%\" class=\"resultssummarytitle2_1\" height=\"30px\">\n                        <div>\n                            Select Your Town &nbsp; &nbsp; &nbsp;&nbsp;\n                            <select name=\"ddlTown\" id=\"ddlTown\" data-ng-options=\"key as value for (key, value) in townIds track by key\"\n                                    style=\"width:150px\" ng-model=\"selectedTown\" data-ng-change=\"selectTowns()\">\n                                <option value=\"\">-- Select Town --</option>\n                            </select>\n                        </div>\n                    </td>\n                </tr>\n            </tbody>\n        </table>\n    </div>\n    <div class=\"colum2\">\n        <table width=\"100%\" cellspacing=\"0\" cellpadding=\"0\">\n            <tbody>\n                <tr>\n                    <td width=\"100%\" height=\"30px\" class=\"resultssummarytitle2\">\n                        <div>\n                            Results by Town -\n                            <span class=\"colorhighlight\" data-ng-if=\"selectTown!=''\">{{townIds[selectTown]}}</span>&nbsp;\n                            <span class=\"resultsstatus\" data-ng-show=\"townStatus[selectTown]['TS']=='( Official Results )'\">{{townStatus[selectTown][\"TS\"]}}</span>\n                            <a href=\"javascript:void(0)\" style=\"text-decoration:none;\" data-ng-show=\"townStatus[selectTown]['TS']=='( *Unofficial Results )'\"\n                               data-ng-click=\"UnofficialResultsMsg();\">\n                                <span class=\"resultsstatus\" data-ng-if=\"townStatus[selectTown]['TS']!=''\">{{townStatus[selectTown][\"TS\"]}}</span>\n                            </a>\n                        </div>\n                    </td>\n                </tr>\n                <tr>\n                    <td class=\"resultssummarytitle2_2\" height=\"30px\">\n                        Precincts Reported:&nbsp;<span data-ng-if=\"selectTown!='' && selectTown!=undefined\">{{townStatus[selectTown][\"PR\"]}} </span><a href=\"\" data-ng-click=\"DownLoadGridReport(currentElectionID,electionName,townIds[selectTown],selectTown);\" data-ng-if=\"selectTown!='' && selectTown!=undefined\">&nbsp; | &nbsp;Ballot Paper</a>\n                    </td>\n                </tr>\n            </tbody>\n        </table>\n    </div>\n    <div class=\"colum2 disable\">\n        <br>\n        <table cellspacing=\"0\" cellpadding=\"0\">\n            <tbody>\n                <tr>\n                    <td style=\"width:80%;\" align=\"left\" valign=\"top\">\n                        <ng-include src=\"'ng-app/partial/TownMap.html'\" frameborder=\"0\" width=\"510\" height=\"400\"></ng-include>\n                    </td>\n                </tr>\n            </tbody>\n        </table>\n    </div>\n    <div id=\"dvTownsStats\" class=\"colum2\">\n        <br>\n        <div data-ng-repeat=\"(key,value) in townVotes\" data-ng-if=\"key==selectTown\">\n            <div data-ng-repeat=\"t in officeList\">\n                <div data-ng-repeat=\"(key3,value3) in t\">\n                    <div data-ng-repeat=\"(key1, value1) in value\" data-ng-if=\"key1==key3\">\n                        <div>\n                            <span class='resultssummarytitle' style='padding-bottom: 8px'>\n                                <a data-ng-click=\"redirectToRaces(key3,value3['OT'],value3['D'])\" style=\"text-decoration: underline; cursor: pointer;\">{{value3[\"NM\"]}}</a>\n                            </span>&nbsp;&nbsp;\n                            <span class='resultsstatus'>( Click here for full race results )</span>\n                        </div>\n                        <table width='100%' cellpadding=3 cellspacing=0>\n                            <tr>\n                                <td class='resultssummaryheader'>CANDIDATE PARTY / NAME</td>\n                                <td align='right' class='resultssummaryheader'>VOTES</td>\n                                <td align='right' class='resultssummaryheader'>VOTES %</td>\n                            </tr>\n                            <tr><td class=\"bggrey1\" colspan=\"3\"><strong>{{value3[\"DT\"]}}</strong></td></tr>\n                            <tbody data-ng-repeat=\"k in value1\">\n                                <tr data-ng-repeat=\"(key2, value2) in k\">\n                                    <td class='resultssummaryvalues'>\n                                        <img title='{{partyIds[candidateIds[key2][\"P\"]][\"NM\"]}}' src='assets/images/spacer.gif' class='{{partyIds[candidateIds[key2][\"P\"]][\"CD\"]}}' />&nbsp;\n                                        <span>{{candidateIds[key2][\"NM\"]}}</span>\n                                    </td>\n                                    <td align='right' class='resultssummaryvalues'>{{k[key2][\"V\"]|number}}</td>\n                                    <td style='font-weight: bold' align='right' class='resultssummaryvalues'>{{k[key2][\"TO\"]}}</td>\n                                </tr>\n                            </tbody>\n                        </table>\n                        <div style=\"padding-bottom:8px;\"></div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n"
          },
