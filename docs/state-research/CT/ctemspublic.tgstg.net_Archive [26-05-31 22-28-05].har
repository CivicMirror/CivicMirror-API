 {\r\n        if (obj.attachEvent && !obj.addEventListener) {\r\n            obj.attachEvent(\"on\" + eventName, callback)\r\n        } else {\r\n            obj.addEventListener(eventName, callback, false)\r\n        }\r\n    };\r\n    var _detachEvent = function(obj, eventName, callback) {\r\n        if (obj.detachEvent && !obj.addEventListener) {\r\n            obj.detachEvent(\"on\" + eventName, callback)\r\n        } else {\r\n            obj.removeEventListener(eventName, callback, false)\r\n        }\r\n    };\r\n    if (jsMin.document.addEventListener) {\r\n        jsMin.document.addEventListener(\"DOMContentLoaded\", jsMin.onreadyInit, false)\r\n    }\r\n    if (/WebKit/i.test(navigator.userAgent)) {\r\n        var _timer = setInterval(function() {\r\n            if (/loaded|complete/.test(jsMin.document.readyState)) {\r\n                jsMin.onreadyInit()\r\n            }\r\n        }, 10)\r\n    }\r\n    _attachEvent(window, \"load\", jsMin.onreadyInit);\r\n    var registerResizableObjs = [];\r\n    jsMin.resizable = function(resizableObj, resizeCallback) {\r\n        registerResizableObjs[registerResizableObjs.length] = {\r\n            resizableObj: resizableObj,\r\n            resizeCallback: resizeCallback\r\n        }\r\n    };\r\n\r\n    function initResizable() {\r\n        var currentObj = null;\r\n\r\n        function resizeObject() {\r\n            this.el = null;\r\n            this.dir = \"\";\r\n            this.grabx = null;\r\n            this.graby = null;\r\n            this.width = null;\r\n            this.height = null;\r\n            this.left = null;\r\n            this.top = null\r\n        }\r\n\r\n        function getDirection(el) {\r\n            var xPos, yPos, offset, dir;\r\n            dir = \"\";\r\n            xPos = window.event.offsetX;\r\n            yPos = window.event.offsetY;\r\n            offset = 8;\r\n            if (yPos < offset) {\r\n                dir += \"n\"\r\n            } else {\r\n                if (y