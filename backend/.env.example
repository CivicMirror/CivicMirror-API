# Django
DJANGO_SECRET_KEY=django-insecure-change-me-for-development
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=config.settings.dev

# Database (defaults to SQLite if not set)
DATABASE_URL=postgres://civicmirror:civicmirror@localhost:5432/civicmirror_api

# Redis (used by Celery)
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1

# Internal task auth (ADR-002 — shared secret for dev/CI; use OIDC in prod)
INTERNAL_TASK_TOKEN=change-me-for-development

# API key auth (Phase 3 — X-Api-Key header from CivicMirror frontend)
CIVICMIRROR_API_KEY=change-me-for-development

# External API keys
CIVIC_API_KEY=
FEC_API_KEY=
OPENSTATES_API_KEY=
GITHUB_TOKEN=

# Google Civic API settings
CIVIC_API_BASE=https://www.googleapis.com/civicinfo/v2
CIVIC_HTTP_TIMEOUT_SECONDS=10
CIVIC_MAX_RETRIES=3
CIVIC_RETRY_BACKOFF_SECONDS=1.0

# Gmail API (ADR-005 — Phase 6, VIP email monitoring)
GMAIL_SERVICE_ACCOUNT_JSON=
VIP_GMAIL_WATCH_TOPIC=
GMAIL_WATCH_USER_ID=

# Logging
LOG_LEVEL=INFO

# Firebase Authentication (v1.1 — mock voting + community races)
# Set FIREBASE_AUTH_ENABLED=False for local dev without Firebase project
FIREBASE_AUTH_ENABLED=False
# Path to service account JSON; leave blank to use Application Default Credentials (Cloud Run)
FIREBASE_CREDENTIALS_FILE=
